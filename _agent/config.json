{
  "agent_name": "gamedevwiki",
  "vault_path": "${GAMEDEVWIKI_ROOT:-.}",
  "model": "claude-sonnet-4-6",
  "max_tokens": 2000,
  "monthly_budget_usd": 22,
  "pricing": {
    "input_per_mtok": 3.0,
    "output_per_mtok": 15.0
  },
  "log_retention_days": 30,
  "watch_paths": {
    "pages": {
      "path": "${GAMEDEVWIKI_ROOT:-.}/10-Library/notes",
      "recursive": true,
      "on_modified": true
    },
    "feed": {
      "path": "${GAMEDEVWIKI_ROOT:-.}/50-Feed",
      "recursive": true,
      "on_modified": true
    }
  },
  "git_auto_commit": false,
  "git_commit_prefix": "chore(gamedevwiki):",
  "debounce_seconds": 3,
  "wiki_root": "${GAMEDEVWIKI_ROOT:-.}/10-Library",
  "notes_root": "${GAMEDEVWIKI_ROOT:-.}/10-Library/notes",
  "sources_root": "${GAMEDEVWIKI_ROOT:-.}/10-Library/sources",
  "feed_root": "${GAMEDEVWIKI_ROOT:-.}/50-Feed",
  "out_dir": "${GAMEDEVWIKI_ROOT:-.}/_agent/out"
}
